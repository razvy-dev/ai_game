# Postgres database credentials

POSTGRES_HOST=your_database_host
POSTGRES_PORT=your_database_port
POSTGRES_NAME=your_database_name
POSTGRES_USER=your_database_user
POSTGRES_PASS=your_database_password

# redis

REDIS_HOST=your_redis_host
REDIS_PORT=6379

# app stuff

LOG_LEVEL=INFO

# allowed origins

FRONTEND_ORIGIN=your_frontend_origin
ADMIN_ORIGIN=your_admin_origin

# authentication stuff

SECRET_KEY=your_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRES_IN_MINUTES=30

# email stuff

RESEND_API_KEY=your_resend_api_key
RESEND_EMAIL_FROM=your_resend_email